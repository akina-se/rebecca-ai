# Server
PORT=8080

# GCP
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=asia-northeast1
GCP_TASK_QUEUE_NAME=rebecca-reply-queue
# デプロイ後にCloud RunのURLを発行し、ここに設定します
WORKER_URL=https://your-cloud-run-service-url.a.run.app

# X API (Free Plan以上)
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
X_BEARER_TOKEN=
X_MY_USER_ID=your-bot-twitter-user-id

# Gemini API
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-3.1-flash-lite
JUDGE_MODEL=gemma-4-31b-it
GEMINI_EMBEDDING_MODEL=text-embedding-004

# Logs & RAG
LOG_RETENTION_DAYS=180
RAG_MAX_MEMORIES=100

# メンション取得頻度（分）
# Pay-As-You-Goプランでの課金防止のため、60など長めに設定することを推奨します。
# ※ Cloud Schedulerを使用せずに自前でローカル定期実行する場合に使われます。
POLLING_INTERVAL_MINUTES=60
