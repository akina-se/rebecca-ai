# Server
PORT=8080

# GCP
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=asia-northeast1
GCP_TASK_QUEUE_NAME=rebecca-reply-queue
# URL for Cloud Run service (to be set after deployment)
WORKER_URL=https://your-cloud-run-service-url.a.run.app

# X API (Free Plan or higher)
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
X_BEARER_TOKEN=
X_MY_USER_ID=your-bot-twitter-user-id

# Gemini API
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-3.1-flash-lite
JUDGE_MODEL=gemma-4-31b-it
GEMINI_EMBEDDING_MODEL=text-embedding-004

# Logs & RAG
LOG_RETENTION_DAYS=180
RAG_MAX_MEMORIES=100

# Mentions Polling Interval (minutes)
# Recommended to set to 60 or higher to avoid unexpected charges on Pay-As-You-Go plans.
# * Used when running locally without Cloud Scheduler.
POLLING_INTERVAL_MINUTES=60
